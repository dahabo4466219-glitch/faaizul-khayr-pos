function toggleTableSelect(){
  var t = document.getElementById('oType').value;
  var lbl = document.getElementById('oTableLbl');
  var sel = document.getElementById('oTable');
  if(t === 'dinein'){ lbl.classList.remove('hidden'); sel.classList.remove('hidden'); }
  else { lbl.classList.add('hidden'); sel.classList.add('hidden'); }
}
function changeQty(id, delta){
  var q = orderCart[id] || 0;
  q += delta;
  if(q < 0) q = 0;
  orderCart[id] = q;
  document.getElementById('qty-' + id).textContent = q;
}
function submitOrder(){
  var items = [];
  var total = 0;
  for(var id in orderCart){
    if(orderCart[id] > 0){
      var it = null;
      for(var i=0;i<db.menu.length;i++){ if(db.menu[i].id === id) it = db.menu[i]; }
      items.push({name: it.name, qty: orderCart[id], price: it.price, cat: it.cat});
      total += it.price * orderCart[id];
    }
  }
  if(items.length === 0){ alert('Fadlan dooro ugu yaraan hal alaab.'); return; }
  var type = document.getElementById('oType').value;
  var typeLabel = type === 'dinein' ? 'Fadhi' : (type === 'takeaway' ? 'Sii qaad' : 'Gaadiid');
  var tableId = null;
  if(type === 'dinein'){
    tableId = parseInt(document.getElementById('oTable').value);
    for(var k=0;k<db.tables.length;k++){ if(db.tables[k].id === tableId) db.tables[k].status = 'busy'; }
    sb.from('restaurant_tables').update({status:'busy'}).eq('id', tableId).then(function(){});
  }
  db.orderSeq++;
  var order = {
    id: db.orderSeq,
    type: type,
    typeLabel: typeLabel,
    tableId: tableId,
    items: items,
    total: total,
    status: 'new',
    date: new Date().toISOString().slice(0,10),
    time: new Date().toISOString()
  };
  db.orders.push(order);
  saveData();
  closeModal('orderModal');
  orderCart = {};
  renderTables();
  if(currentPage === 'orders') renderOrders();
  if(currentPage === 'menu') renderMenu();
  updateCartBar();
  sb.from('orders').insert(orderObjToRow(order)).then(function(){});
  alert('Dalabka waa la diray! #ORD-' + order.id);
}

