var activeStation = 'all';
var stations = [
  {id:'kitchen', ic:'🍳', lb:'Cuntada'},
  {id:'drinks', ic:'🥤', lb:'Sharaabta'},
  {id:'desserts', ic:'🍰', lb:'Macmacaanka'}
];
function getStation(cat){
  if(cat === 'Drinks') return 'drinks';
  if(cat === 'Desserts') return 'desserts';
  return 'kitchen';
}
function stationLabel(id){
  for(var i=0;i<stations.length;i++){ if(stations[i].id === id) return stations[i].lb; }
  return id;
}
function countStationItems(stationId){
  var n = 0;
  for(var i=0;i<db.orders.length;i++){
    var o = db.orders[i];
    if(o.status !== 'new') continue;
    for(var j=0;j<o.items.length;j++){
      if(getStation(o.items[j].cat) === stationId) n += o.items[j].qty;
    }
  }
  return n;
}
function renderKDS(){
  var active = [];
  for(var i=0;i<db.orders.length;i++){
    if(db.orders[i].status === 'new') active.push(db.orders[i]);
  }
  var html = '';
  for(var s=0;s<stations.length;s++){
    var stId = stations[s].id;
    var cnt = countStationItems(stId);
    html += '<div class="sectitle" style="margin-top:18px;"><span>' + stations[s].ic + ' ' + stations[s].lb + '</span><span class="badge gray">' + cnt + '</span></div>';
    var shown = 0;
    for(var j=0;j<active.length;j++){
      var o = active[j];
      var filteredItems = [];
      for(var k=0;k<o.items.length;k++){
        if(getStation(o.items[k].cat) === stId) filteredItems.push(o.items[k]);
      }
      if(filteredItems.length === 0) continue;
      shown++;
      html += '<div class="kcard">';
      html += '<div class="khead"><span>#ORD-' + o.id + ' - ' + o.typeLabel + (o.tableId ? ' Miis ' + o.tableId : '') + '</span><span class="timer">🕒 New</span></div>';
      for(var m=0;m<filteredItems.length;m++){
        html += '<div class="kitem">✅ ' + filteredItems[m].qty + 'x ' + filteredItems[m].name + '</div>';
      }
      html += '<button class="btn sm" style="margin-top:10px;" onclick="markOrderReady(' + o.id + ')">Diyaar (Ready)</button>';
      html += '</div>';
    }
    if(shown === 0){ html += '<div class="empty">Wax dalab ah ma jiraan qaybtan</div>'; }
  }
  document.getElementById('kdsList').innerHTML = html;
}
function markOrderReady(id){
  for(var i=0;i<db.orders.length;i++){
    if(db.orders[i].id === id) db.orders[i].status = 'ready';
  }
  saveData();
  renderKDS();
  sb.from('orders').update({status:'ready'}).eq('id', id).then(function(){});
}

/* ---------- INVENTORY ---------- */
function renderInv(){
  var html = '';
  if(db.inventory.length === 0){ html = '<div class="empty">Bakhaar wax ku jira ma jiraan</div>'; }
  for(var i=0;i<db.inventory.length;i++){
    var it = db.inventory[i];
    var low = it.qty <= it.low;
    html += '<div class="card"><div class="row"><div><b>' + it.name + '</b><div style="font-size:12px;color:var(--mut);">Stock: ' + it.qty + '</div></div>';
    html += '<span class="badge ' + (low ? 'red' : 'green') + '">' + (low ? 'Yar' : 'OK') + '</span></div>';
    if(currentRole === 'manager'){
      html += '<div style="margin-top:8px;display:flex;gap:8px;">';
      html += '<button class="btn sm gray" onclick="openInvModal(\'' + it.id + '\')">✏️ Edit</button>';
      html += '<button class="btn sm red" onclick="deleteInvItem(\'' + it.id + '\')">🗑️</button>';
      html += '</div>';
    }
    html += '</div>';
  }
  document.getElementById('invList').innerHTML = html;
}
function openInvModal(id){
  document.getElementById('invEditId').value = id || '';
  if(id){
    var it = null;
    for(var i=0;i<db.inventory.length;i++){ if(db.inventory[i].id === id) it = db.inventory[i]; }
    document.getElementById('invModalTitle').textContent = 'Wax ka beddel Alaabta';
    document.getElementById('invName').value = it.name;
    document.getElementById('invQty').value = it.qty;
    document.getElementById('invLow').value = it.low;
  } else {
    document.getElementById('invModalTitle').textContent = 'Ku dar Alaab Bakhaar';
    document.getElementById('invName').value = '';
    document.getElementById('invQty').value = '';
    document.getElementById('invLow').value = '';
  }
  document.getElementById('invModal').classList.add('open');
}
function saveInvItem(){
  var id = document.getElementById('invEditId').value;
  var name = document.getElementById('invName').value.trim();
  var qty = parseInt(document.getElementById('invQty').value);
  var low = parseInt(document.getElementById('invLow').value);
  if(!name || isNaN(qty) || isNaN(low)){ alert('Fadlan buuxi dhammaan xogta.'); return; }
  var newId = id || uid();
  if(id){
    for(var i=0;i<db.inventory.length;i++){
      if(db.inventory[i].id === id){ db.inventory[i].name = name; db.inventory[i].qty = qty; db.inventory[i].low = low; }
    }
  } else {
    db.inventory.push({id: newId, name: name, qty: qty, low: low});
  }
  saveData();
  closeModal('invModal');
  renderInv();
  sb.from('inventory_items').upsert({id: newId, name: name, qty: qty, low: low}).then(function(){});
}
function deleteInvItem(id){
  if(!confirm('Ma hubtaa inaad tirtirto?')) return;
  var newInv = [];
  for(var i=0;i<db.inventory.length;i++){ if(db.inventory[i].id !== id) newInv.push(db.inventory[i]); }
  db.inventory = newInv;
  saveData();
  renderInv();
  sb.from('inventory_items').delete().eq('id', id).then(function(){});
}

/* ---------- REPORTS ---------- */
function renderReports(){
  var totalSales = 0;
  var itemCount = {};
  for(var i=0;i<db.orders.length;i++){
    var o = db.orders[i];
    totalSales += o.total;
    for(var j=0;j<o.items.length;j++){
      var nm = o.items[j].name;
      itemCount[nm] = (itemCount[nm] || 0) + o.items[j].qty;
    }
  }
  document.getElementById('rTotalSales').textContent = '$' + totalSales.toFixed(2);
  document.getElementById('rTotalOrders').textContent = db.orders.length;
  var avg = db.orders.length > 0 ? totalSales / db.orders.length : 0;
  document.getElementById('rAvgOrder').textContent = '$' + avg.toFixed(2);

  var arr = [];
  for(var nm2 in itemCount){ arr.push({name: nm2, qty: itemCount[nm2]}); }
  arr.sort(function(a,b){ return b.qty - a.qty; });
  arr = arr.slice(0,5);
  var html = '';
  if(arr.length === 0){ html = '<div class="empty">Weli xog lama helin</div>'; }
  for(var k=0;k<arr.length;k++){
    html += '<div class="card row"><span>' + arr[k].name + '</span><b>' + arr[k].qty + 'x</b></div>';
  }
  document.getElementById('topItems').innerHTML = html;
}

function exportCSV(){
  var csv = 'Order ID,Type,Table,Items,Total,Status,Date\n';
  for(var i=0;i<db.orders.length;i++){
    var o = db.orders[i];
    var itemsStr = '';
    for(var j=0;j<o.items.length;j++){
      itemsStr += o.items[j].qty + 'x ' + o.items[j].name + '; ';
    }
    csv += o.id + ',' + o.typeLabel + ',' + (o.tableId || '-') + ',"' + itemsStr + '",' + o.total.toFixed(2) + ',' + o.status + ',' + o.date + '\n';
  }
  var blob = new Blob([csv], {type: 'text/csv'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'orders_report.csv';
  a.click();
  URL.revokeObjectURL(url);
}

