function deleteMenuItem(id){
  if(!confirm('Ma hubtaa inaad tirtirto alaabtan?')) return;
  var newMenu = [];
  for(var i=0;i<db.menu.length;i++){ if(db.menu[i].id !== id) newMenu.push(db.menu[i]); }
  db.menu = newMenu;
  saveData();
  renderMenu();
  sb.from('menu_items').delete().eq('id', id).then(function(){});
}

