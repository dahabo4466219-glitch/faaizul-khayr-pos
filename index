  for(var i=0;i<db.orders.length;i++){
    if(db.orders[i].status !== 'done') active.push(db.orders[i]);
  }
  active.reverse();
  if(active.length === 0){ html = '<div class="empty">Dalab firfircoon lama helin</div>'; }
  for(var j=0;j<active.length;j++){
    var o = active[j];
    var badgeClass = o.status === 'new' ? 'amber' : 'green';
    html += '<div class="card">';
    html += '<div class="row"><b>#ORD-' + o.id + '</b><span class="badge ' + badgeClass + '">' + o.status + '</span></div>';
    html += '<div style="font-size:12px;color:var(--mut);margin:4px 0;">' + o.typeLabel + (o.tableId ? ' - Miis ' + o.tableId : '') + '</div>';
    for(var k=0;k<o.items.length;k++){
      html += '<div style="font-size:13px;">' + o.items[k].qty + 'x ' + o.items[k].name + '</div>';
    }
    html += '<div class="row" style="margin-top:8px;"><b>$' + o.total.toFixed(2) + '</b>';
    if(o.status !== 'done'){
      html += '<button class="btn sm" onclick="markOrderDone(' + o.id + ')">Dhammee (Done)</button>';
    }
    html += '</div></div>';
  }
  document.getElementById('activeOrders').innerHTML = html;
}
function markOrderDone(id){
  var order = null;
  var freedTableId = null;
  for(var i=0;i<db.orders.length;i++){
    if(db.orders[i].id === id){
      db.orders[i].status = 'done';
      order = db.orders[i];
      if(db.orders[i].tableId){
        for(var j=0;j<db.tables.length;j++){
          if(db.tables[j].id === db.orders[i].tableId){ db.tables[j].status = 'free'; freedTableId = db.tables[j].id; }
        }
      }
    }
  }
  saveData();
  renderOrders();
  renderTables();
  if(order) showInvoice(order);
  sb.from('orders').update({status:'done'}).eq('id', id).then(function(){});
  if(freedTableId){ sb.from('restaurant_tables').update({status:'free'}).eq('id', freedTableId).then(function(){}); }
}

function showInvoiceById(id){
  var order = null;
  for(var i=0;i<db.orders.length;i++){ if(db.orders[i].id === id) order = db.orders[i]; }
  if(order) showInvoice(order);
}
