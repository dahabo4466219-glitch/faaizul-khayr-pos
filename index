function saveMenuItem(){
  var id = document.getElementById('menuEditId').value;
  var name = document.getElementById('mName').value.trim();
  var cat = document.getElementById('mCat').value.trim();
  var price = parseFloat(document.getElementById('mPrice').value);
  if(!name || !cat || isNaN(price)){ alert('Fadlan buuxi dhammaan xogta.'); return; }
  var newId = id || uid();
  if(id){
    for(var i=0;i<db.menu.length;i++){
      if(db.menu[i].id === id){ db.menu[i].name = name; db.menu[i].cat = cat; db.menu[i].price = price; }
    }
  } else {
    db.menu.push({id: newId, name: name, cat: cat, price: price});
  }
  saveData();
  closeModal('menuModal');
  renderMenu();
  sb.from('menu_items').upsert({id: newId, name: name, cat: cat, price: price}).then(function(){});
