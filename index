<script>
var SUPABASE_URL = 'https://kpxwovwzmfreeznuolcg.supabase.co';
var SUPABASE_KEY = 'sb_publishable_OHev8ueZAzxrx6hi592Pyw_OxHTY1tj';
var sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

var STORE_KEY = 'faaizulkhayr_pos_data_v1';
var currentRole = null;
var currentPage = 'dash';
var db = null;
var dataReady = false;

function defaultData(){
  return {
    menu: [
      {id:'m1', name:'Chicken Burger', cat:'Burgers', price:5.50},
      {id:'m2', name:'Margherita Pizza', cat:'Pizza', price:8.00},
      {id:'m3', name:'Iced Coffee', cat:'Drinks', price:3.20},
      {id:'m4', name:'Beef Burger', cat:'Burgers', price:6.00},
      {id:'m5', name:'Pepperoni Pizza', cat:'Pizza', price:9.50},
      {id:'m6', name:'Orange Juice', cat:'Drinks', price:2.50},
      {id:'m7', name:'Chocolate Cake', cat:'Desserts', price:4.00}
    ],
    tables: [
      {id:1,status:'free'},{id:2,status:'free'},{id:3,status:'busy'},
      {id:4,status:'free'},{id:5,status:'busy'},{id:6,status:'free'},
      {id:7,status:'free'},{id:8,status:'free'},{id:9,status:'busy'}
    ],
    inventory: [
      {id:'i1', name:'Chicken', qty:18, low:5},
      {id:'i2', name:'Cheese', qty:4, low:5},
      {id:'i3', name:'Beef', qty:12, low:5},
      {id:'i4', name:'Coffee Beans', qty:25, low:8}
    ],
    orders: [],
    orderSeq: 100
  };
}

/* ---------- Supabase row <-> app object mapping ---------- */
function orderRowToObj(r){
  return {
    id: r.id, type: r.type, typeLabel: r.type_label, tableId: r.table_id,
    items: r.items, total: Number(r.total), status: r.status,
    date: r.order_date, time: r.order_time
  };
}
function orderObjToRow(o){
  return {
    id: o.id, type: o.type, type_label: o.typeLabel, table_id: o.tableId || null,
    items: o.items, total: o.total, status: o.status,
    order_date: o.date, order_time: o.time
  };
}

/* ---------- Load / Save (Supabase-backed, with localStorage fallback) ---------- */
function loadData(){
  var raw = null;
  try{ raw = localStorage.getItem(STORE_KEY); }catch(e){ raw = null; }
  if(raw){
    try{ db = JSON.parse(raw); }catch(e){ db = defaultData(); }
  } else {
    db = defaultData();
  }
}
function saveData(){
  try{ localStorage.setItem(STORE_KEY, JSON.stringify(db)); }catch(e){}
}

async function loadFromSupabase(){
  loadData();
  try{
    var results = await Promise.all([
      sb.from('menu_items').select('*').order('name'),
      sb.from('restaurant_tables').select('*').order('id'),
      sb.from('inventory_items').select('*').order('name'),
      sb.from('orders').select('*').order('id')
    ]);
    var menuRes = results[0], tablesRes = results[1], invRes = results[2], ordersRes = results[3];
    if(!menuRes.error && menuRes.data){ db.menu = menuRes.data; }
    if(!tablesRes.error && tablesRes.data){ db.tables = tablesRes.data; }
    if(!invRes.error && invRes.data){ db.inventory = invRes.data; }
    if(!ordersRes.error && ordersRes.data){
      db.orders = ordersRes.data.map(orderRowToObj);
      var maxId = 100;
      for(var i=0;i<db.orders.length;i++){ if(db.orders[i].id > maxId) maxId = db.orders[i].id; }
      db.orderSeq = maxId;
    }
    saveData();
    dataReady = true;
  }catch(e){
    dataReady = true;
  }
}

function subscribeRealtime(){
  try{
    sb.channel('faaizulkhayr-live')
      .on('postgres_changes', {event:'*', schema:'public', table:'menu_items'}, onRemoteChange)
      .on('postgres_changes', {event:'*', schema:'public', table:'restaurant_tables'}, onRemoteChange)
      .on('postgres_changes', {event:'*', schema:'public', table:'inventory_items'}, onRemoteChange)
      .on('postgres_changes', {event:'*', schema:'public', table:'orders'}, onRemoteChange)
      .subscribe();
  }catch(e){}
}
var remoteRefreshTimer = null;
function onRemoteChange(){
  if(remoteRefreshTimer) clearTimeout(remoteRefreshTimer);
  remoteRefreshTimer = setTimeout(async function(){
    await loadFromSupabase();
    if(currentRole){
      if(currentPage === 'dash') renderDash();
      if(currentPage === 'menu') renderMenu();
      if(currentPage === 'tables') renderTables();
      if(currentPage === 'orders') renderOrders();
      if(currentPage === 'kds') renderKDS();
      if(currentPage === 'inv') renderInv();
      if(currentPage === 'reports') renderReports();
    }
  }, 500);
}

