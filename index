/* ---------- DASHBOARD ---------- */
function renderDash(){
  var today = new Date().toISOString().slice(0,10);
  var todayOrders = [];
  for(var i=0;i<db.orders.length;i++){
    if(db.orders[i].date === today) todayOrders.push(db.orders[i]);
  }
  var totalSales = 0;
  for(var j=0;j<todayOrders.length;j++){ totalSales += todayOrders[j].total; }
  var profit = totalSales * 0.28;

  var allTotal = 0;
  for(var m=0;m<db.orders.length;m++){ allTotal += db.orders[m].total; }
  var trendPct = allTotal > 0 ? Math.round((totalSales / (allTotal + 0.01)) * 100) : 0;

  document.getElementById('dSales').textContent = '$' + totalSales.toFixed(2);
  document.getElementById('dSalesSub').textContent = '+' + trendPct + '% vs last week';
  document.getElementById('dOrders').textContent = todayOrders.length;
  document.getElementById('dOrdersSub').textContent = 'Maanta';
  document.getElementById('dProfit').textContent = '$' + profit.toFixed(2);
  document.getElementById('dProducts').textContent = db.menu.length;

  var recent = db.orders.slice(-5).reverse();
  var html = '';
  if(recent.length === 0){
    html = '<div class="empty">Wali dalab lama helin</div>';
  }
  var statusLabels = {new:'Sugaya', ready:'Diyaar', done:'Completed'};
  for(var k=0;k<recent.length;k++){
    var o = recent[k];
    var badgeClass = 'gray';
    if(o.status === 'new') badgeClass = 'amber';
    if(o.status === 'ready') badgeClass = 'green';
    if(o.status === 'done') badgeClass = 'gray';
    html += '<div class="ordrow" onclick="showInvoiceById(' + o.id + ')" style="cursor:pointer;"><div><div class="oid">#ORD-' + ('0000'+o.id).slice(-5) + '</div><div class="otype">' + o.typeLabel + '</div></div>';
    html += '<div><div class="oamt">$' + o.total.toFixed(2) + '</div><span class="badge ' + badgeClass + '">' + statusLabels[o.status] + '</span></div></div>';
  }
  document.getElementById('recentOrders').innerHTML = html;
}

/* ---------- MENU ---------- */
function getCategories(){
  var cats = [];
  for(var i=0;i<db.menu.length;i++){
    if(cats.indexOf(db.menu[i].cat) === -1) cats.push(db.menu[i].cat);
  }
  return cats;
}
var activeCat = 'all';
var catIcons = {'Burgers':'🍔','Pizza':'🍕','Drinks':'🥤','Desserts':'🍰'};
function catIcon(cat){ return catIcons[cat] || '🍽️'; }
function countInCat(cat){
  var n = 0;
  for(var i=0;i<db.menu.length;i++){ if(db.menu[i].cat === cat) n++; }
  return n;
}
function renderMenu(){
  var cats = getCategories();
  var chipHtml = '<span class="catchip' + (activeCat==='all' ? ' act' : '') + '" onclick="filterCat(\'all\')">Dhammaan (' + db.menu.length + ')</span>';
  for(var i=0;i<cats.length;i++){
    var cnt = countInCat(cats[i]);
    var cntStr = cnt < 10 ? '0' + cnt : '' + cnt;
    chipHtml += '<span class="catchip' + (activeCat===cats[i] ? ' act' : '') + '" onclick="filterCat(\'' + cats[i] + '\')">' + cats[i] + ' (' + cntStr + ')</span>';
  }
  document.getElementById('catChips').innerHTML = chipHtml;

  var html = '<div class="pgrid">';
  var shown = 0;
  for(var j=0;j<db.menu.length;j++){
    var it = db.menu[j];
    if(activeCat !== 'all' && it.cat !== activeCat) continue;
    shown++;
    var qtyInCart = orderCart[it.id] || 0;
    html += '<div class="pcard">';
    html += '<div class="pimg">' + catIcon(it.cat) + '</div>';
    html += '<div class="pnm">' + it.name + '</div>';
    html += '<div class="ppr">$' + it.price.toFixed(2) + '</div>';
    if(qtyInCart > 0){
      html += '<div class="qtybtns" style="justify-content:space-between;"><button onclick="cartQty(\'' + it.id + '\',-1)">-</button><span>' + qtyInCart + '</span><button onclick="cartQty(\'' + it.id + '\',1)">+</button></div>';
    } else {
      html += '<button class="paddbtn" onclick="cartQty(\'' + it.id + '\',1)">Add to Cart</button>';
    }
    if(currentRole === 'manager'){
      html += '<div class="pedit"><button class="btn sm gray" style="flex:1;" onclick="openMenuModal(\'' + it.id + '\')">✏️</button><button class="btn sm red" style="flex:1;" onclick="deleteMenuItem(\'' + it.id + '\')">🗑️</button></div>';
    }
    html += '</div>';
  }
  html += '</div>';
  if(shown === 0){ html = '<div class="empty">Alaab lagama helin qaybtan</div>'; }
  document.getElementById('menuList').innerHTML = html;
  updateCartBar();
}
function filterCat(c){ activeCat = c; renderMenu(); }
function cartQty(id, delta){
  var q = orderCart[id] || 0;
  q += delta;
  if(q < 0) q = 0;
  orderCart[id] = q;
  renderMenu();
}
function updateCartBar(){
  var count = 0, total = 0;
  for(var id in orderCart){
    if(orderCart[id] > 0){
      count += orderCart[id];
      var it = null;
      for(var i=0;i<db.menu.length;i++){ if(db.menu[i].id === id) it = db.menu[i]; }
      if(it) total += it.price * orderCart[id];
    }
  }
  var bar = document.getElementById('cartBar');
  if(count > 0 && currentPage === 'menu'){
    bar.classList.add('show');
    document.getElementById('cartInfo').textContent = count + ' alaab - $' + total.toFixed(2);
  } else {
    bar.classList.remove('show');
  }
}
